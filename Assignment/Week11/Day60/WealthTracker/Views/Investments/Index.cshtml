@model IEnumerable<WealthTracker.Models.Investment>

@{
    ViewData["Title"] = "Index";
    var investments = Model!=null ?Model: new List<Investment>();
    var totalPortfolio = investments.Sum(i => i.PurchasePrice * i.Quantity);
    var count = investments.Count();
}

<h1 class="mb-4">Investments</h1>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="card-subtitle mb-2 text-muted">Total Portfolio Value</h6>
                    <h3 class="card-title mb-0">@totalPortfolio.ToString("C")</h3>
                </div>
                <div class="text-end">
                    <small class="text-muted">Investments</small>
                    <div class="h4 mb-0">@count</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 d-flex align-items-center justify-content-end">
        <a asp-action="Create" class="btn btn-primary">Create New Investment</a>
    </div>
</div>

<table class="table table-striped table-hover align-middle">
    <thead class="table-light">
        <tr>
            <th>@Html.DisplayNameFor(model => model.TickerSymbol)</th>
            <th>@Html.DisplayNameFor(model => model.AssetName)</th>
            <th class="text-end">@Html.DisplayNameFor(model => model.PurchasePrice)</th>
            <th class="text-end">@Html.DisplayNameFor(model => model.Quantity)</th>
            <th>@Html.DisplayNameFor(model => model.PurchaseDate)</th>
            <th class="text-end">Total Value</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in investments)
        {
            var rowTotal = item.PurchasePrice * item.Quantity;
            <tr>
                <td>@Html.DisplayFor(modelItem => item.TickerSymbol)</td>
                <td>@Html.DisplayFor(modelItem => item.AssetName)</td>
                <td class="text-end">@item.PurchasePrice.ToString("C")</td>
                <td class="text-end">@item.Quantity</td>
                <td>@item.PurchaseDate.ToShortDateString()</td>
                <td class="text-end">@rowTotal.ToString("C")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info ms-1">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger ms-1">Delete</a>
                </td>
            </tr>
        }
    </tbody>
    @* <tfoot>
        <tr>
            <td colspan="5" class="text-end fw-bold">Total Portfolio</td>
            <td class="text-end fw-bold">@totalPortfolio.ToString("C")</td>
            <td></td>
        </tr>
    </tfoot> *@
</table>

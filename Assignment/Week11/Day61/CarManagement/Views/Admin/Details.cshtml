@model IdentityUser
@using Microsoft.AspNetCore.Identity

<h2>User Details</h2>

<div class="card p-3">
    <p><strong>Email:</strong> @Model.Email</p>

    <p><strong>Roles:</strong></p>
    <ul>
        @foreach (var role in ViewBag.Roles)
        {
            <li>@role</li>
        }
    </ul>
</div>

<br />

<a asp-action="Index" class="btn btn-secondary">Back</a>
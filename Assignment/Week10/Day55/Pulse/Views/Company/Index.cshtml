@model List<Pulse.Models.Emp>
@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>
<div class="alert alert-success">

<h2 class="text text-primary">DepartmentName-@ViewData["deptname"]</h2>
</div>
@if ((bool)ViewData["serverStatus"])
{
    <h1>Department is Active</h1>
}
else{
    <h1>Under Maintenance</h1>
}
<table class="table table-striped table-bordered table-hover">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Salary</th>
            <th>Position</th>
        </tr>

    </thead>
    <tbody>
            @foreach(var i in Model)
            {
        <tr>
                <td>@i.EmpID</td>
                <td>@i.EmpName</td>
                <td>@i.Salary</td>
                <td>@i.Position</td>
                
        </tr>
            }
    </tbody>
</table>
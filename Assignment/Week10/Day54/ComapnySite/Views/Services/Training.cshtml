@{
    ViewData["Title"] = "Training";
}

<div class="container mt-4">

    <h1 class="text-center mb-4">Training Programs</h1>

    <div class="row">

        <div class="col-md-4 mb-4">
            <div class="card shadow">
                <div class="card-body text-center">
                    <h5 class="card-title">Web Development</h5>
                    <p class="card-text">
                        Learn HTML, CSS, JavaScript, and Bootstrap to build modern responsive websites.
                    </p>
                    <a href="#" class="btn btn-primary">Learn More</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card shadow">
                <div class="card-body text-center">
                    <h5 class="card-title">ASP.NET Core MVC</h5>
                    <p class="card-text">
                        Build powerful web applications using ASP.NET Core MVC and C#.
                    </p>
                    <a href="#" class="btn btn-primary">Learn More</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card shadow">
                <div class="card-body text-center">
                    <h5 class="card-title">Database & SQL</h5>
                    <p class="card-text">
                        Understand database design, SQL queries, and data management.
                    </p>
                    <a href="#" class="btn btn-primary">Learn More</a>
                </div>
            </div>
        </div>

    </div>

</div>
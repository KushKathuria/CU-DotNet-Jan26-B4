@{
    ViewData["Title"] = "Home Page";
}

<div class="container mt-4">
    <div class="p-5 mb-4 bg-light rounded-3 text-center">
        <h1 class="display-4 text-primary">Welcome to Company Portal</h1>
        <p class="lead">We provide consulting, training, and software solutions.</p>

        <button class="btn btn-primary btn-lg" id="learnMoreBtn">
            Learn More
        </button>
    </div>

    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 11">

        <div id="learnToast" class="toast">

            <div class="toast-header">
                <strong class="me-auto">CompanySite</strong>
                <small>Now</small>
                <button type="button" class="btn-close" data-bs-dismiss="toast"></button>
            </div>

            <div class="toast-body">
                Welcome! Explore our services, products, and training programs.
            </div>

        </div>

    </div>

</div>

<script>

document.getElementById("learnMoreBtn").addEventListener("click", function () {

var toastElement = document.getElementById("learnToast");
var toast = new bootstrap.Toast(toastElement);

toast.show();

});
</script>
    <div class="row">

        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <h5 class="card-title">Consulting</h5>
                    <p class="card-text">Professional IT consulting services.</p>
                    <a href="/Services/Consulting" class="btn btn-success">View Service</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <h5 class="card-title">Training</h5>
                    <p class="card-text">Industry-level training programs.</p>
                    <a href="/Services/Training" class="btn btn-success">View Training</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <h5 class="card-title">Products</h5>
                    <p class="card-text">Modern software products for businesses.</p>
                    <a href="/Products/Software" class="btn btn-success">View Products</a>
                </div>
            </div>
        </div>

    </div>

</div>
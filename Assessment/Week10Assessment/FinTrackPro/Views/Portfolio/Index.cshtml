@model IEnumerable<FinTrackPro.Models.Assets>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

@{
    double value = (double)ViewData["Total"] + 500;
}

<h3 class="alert alert-info">Total Portfolio Value: @value</h3>

<table class="table">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Name)</th>
            <th>@Html.DisplayNameFor(model => model.PurchasePrice)</th>
            <th>@Html.DisplayNameFor(model => model.Type)</th>
            <th>@Html.DisplayNameFor(model => model.PurchaseDate)</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Name)</td>
                <td>@Html.DisplayFor(modelItem => item.PurchasePrice)</td>
                <td>@Html.DisplayFor(modelItem => item.Type)</td>
                <td>@Html.DisplayFor(modelItem => item.PurchaseDate)</td>

                <td>
                    <a asp-action="Details" asp-route-id="@item.ID">Details</a>                    <a asp-action="Delete" asp-route-id="@item.ID"
                           onclick="return confirm('Are you sure you want to delete this asset?');">
                        Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
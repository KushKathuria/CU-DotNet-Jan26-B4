@model IEnumerable<FinTrackPro.Models.Account>

@{
    ViewData["Title"] = "Index";
}

<h1>Accounts</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>

<table class="table">

    <thead>
        <tr>
            <th>Account Number</th>
            <th>Account Holder</th>
            <th>Balance</th>
            <th></th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.AccountNumber</td>
                <td>@item.AccountHolder</td>
                <td>@item.Balance</td>

                <td>
                    <a asp-action="Edit" asp-route-id="@item.AccountID">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.AccountID">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.AccountID">Delete</a>
                </td>
            </tr>

            <tr>
                <td colspan="4">

                    <strong>Transactions:</strong>

                    <table class="table table-sm">

                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Description</th>
                                <th>Category</th>
                                <th>Amount</th>
                            </tr>
                        </thead>

                        <tbody>

                            @if (item.Transactions != null && item.Transactions.Any())
                            {
                                foreach (var t in item.Transactions)
                                {
                                    <tr>
                                        <td>@t.Date.ToShortDateString()</td>
                                        <td>@t.Description</td>
                                        <td>@t.Category</td>
                                        <td>@t.Amount</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4">No transactions found</td>
                                </tr>
                            }

                        </tbody>

                    </table>

                </td>
            </tr>
        }

    </tbody>

</table>